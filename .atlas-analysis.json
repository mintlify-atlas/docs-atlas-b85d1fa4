  "keyFeatures": [
    "Multi-dialect support: PostgreSQL, MySQL, MariaDB, SQLite, MSSQL, Oracle, Snowflake, DB2, IBM i",
    "Full TypeScript support with decorators and type inference",
    "Rich association system: BelongsTo, HasOne, HasMany, BelongsToMany",
    "Robust transaction support with savepoints and CLS",
    "Lifecycle hooks for models and queries",
    "Model validation and instance methods",
    "Eager and lazy loading of associations",
    "Scopes for reusable query conditions",
    "Connection pooling and read replication",
    "CLI for migrations and seeders"
  ],
  "publicApiSurface": [
    "Sequelize (class)",
